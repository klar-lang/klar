{
  "name": "klar-lang",
  "displayName": "Klar Language",
  "description": "Klar language support — syntax highlighting, diagnostics, hover, completions, and go-to-definition",
  "version": "0.1.0",
  "publisher": "klar-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:klar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "klar",
        "aliases": ["Klar", "klar"],
        "extensions": [".klar"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "klar",
        "scopeName": "source.klar",
        "path": "./syntaxes/klar.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Klar",
      "properties": {
        "klar.lsp.path": {
          "type": "string",
          "default": "klar-lsp",
          "description": "Path to the klar-lsp binary"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
