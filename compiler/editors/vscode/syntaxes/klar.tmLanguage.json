{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Klar",
  "scopeName": "source.klar",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#annotations" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.klar",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.klar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.klar",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.klar",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.klar",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.klar",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.klar",
          "match": "\\b(if|else|for|in|match|return|break|loop)\\b"
        },
        {
          "name": "keyword.declaration.klar",
          "match": "\\b(fn|let|mut|struct|enum|trait|impl|use|test|priv)\\b"
        },
        {
          "name": "keyword.operator.klar",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.klar",
          "match": "\\b(catch|else)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.klar",
          "match": "\\b(Int|Float|Bool|String|Byte|List|Map|Set|Option|Result)\\b"
        },
        {
          "name": "entity.name.type.custom.klar",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.klar",
          "match": "@[a-z_][a-z_0-9]*",
          "captures": {
            "0": { "name": "entity.name.function.decorator.klar" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.klar",
          "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.klar" },
            "2": { "name": "entity.name.function.klar" }
          }
        },
        {
          "name": "entity.name.function.call.klar",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.klar" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.klar",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.klar",
          "match": "->"
        },
        {
          "name": "keyword.operator.error.klar",
          "match": "!"
        },
        {
          "name": "keyword.operator.range.klar",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.comparison.klar",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.klar",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.klar",
          "match": "="
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.klar",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.klar",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
