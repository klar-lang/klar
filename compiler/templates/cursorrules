## HTTP API Pattern

```klar
use std.http.{Router, Request, Response, serve}

@schema
struct User {
  name: String @min_len(1)
  email: String
}

fn get_user(req: Request) -> Response {
  Response.json(User { name: "Alice", email: "alice@example.com" })
}

fn main() {
  let router = Router.new()
  router.get("/user/:id", get_user)
  serve(router, 3000)
}
```
